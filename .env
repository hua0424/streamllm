# 模型配置 - 统一使用指定模型进行公平比较
LLM_MODEL_NAME="Qwen/Qwen1.5-0.5B-Chat"  # 指定的LLM模型
ASR_MODEL_NAME="base"  # faster-whisper模型大小，所有模式统一使用

# Hugging Face配置
HF_HOME="./cache"
HF_ENDPOINT=""
HF_TOKEN=""

# 数据路径
DATA_DIR="data"
RAW_AUDIO_DIR="data/raw_audio"
PROCESSED_AUDIO_DIR="data/processed_audio"
TRANSCRIPTS_DIR="data/transcripts"

# 实验结果路径
RESULTS_DIR="results"
LATENCY_METRICS_DIR="results/latency_metrics"
WER_SCORES_DIR="results/wer_scores"

# 日志配置
LOG_LEVEL="INFO"
LOG_FILE="logs/experiment.log"

# 音频格式配置
TARGET_SAMPLE_RATE="16000"
TARGET_CHANNELS="1"